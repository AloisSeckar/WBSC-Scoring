{
  "name": "wbsc-scoring",
  "version": "1.5.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "eslint": "eslint .",
    "postinstall": "nuxt prepare",
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "start": "node .output/server/index.mjs",
    "test": "pnpm test-validations && pnpm test-actions && pnpm test-screenshots",
    "test-actions": "vitest run --project actions",
    "test-screenshots": "vitest run --project screenshots",
    "test-validations": "vitest run --project validations",
    "test-update": "vitest run --project actions -u && vitest run --project screenshots -u"
  },
  "devDependencies": {
    "nuxt-ignis": "0.6.0"
  },
  "packageManager": "pnpm@11.12.0"
}
