
{
    // enable auto-linting
    "editor.codeActionsOnSave": {
        "source.fixAll": "explicit",
        "source.fixAll.eslint": "explicit"
    },
    // enable ESlint flat config
    "eslint.useFlatConfig": true,
    // markdownlint - do NOT treat LICENSE file as markdown
    "files.associations": {
      "LICENSE": "plaintext"
    }
}
